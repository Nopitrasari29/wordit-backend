// ============================================================
// CONFIGURATION
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EducationLevel {
  SD
  SMP
  SMA
  UNIVERSITY
}

enum TemplateType {
  // Sprint 2 Templates
  ANAGRAM
  FLASHCARD
  HANGMAN
  MAZE_CHASE
  SPIN_THE_WHEEL
  WORD_SEARCH

  // Sprint 3 Standard Assessment Templates [NEW]
  MULTIPLE_CHOICE
  TRUE_FALSE
  MATCHING
  ESSAY
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

// ============================================================
// USER MODELS
// ============================================================

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role            @default(STUDENT)
  approvalStatus ApprovalStatus  @default(APPROVED)
  educationLevel EducationLevel?
  photoUrl       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  profile      UserProfile?
  gamesCreated Game[]        @relation("GameCreator")
  sessions     GameSession[]

  @@map("users")
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  bio         String?
  totalPoints Int      @default(0)
  badges      Json     @default("[]")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ============================================================
// GAME MODELS
// ============================================================

model Game {
  id             String          @id @default(uuid())
  title          String
  description    String?
  templateType   TemplateType
  educationLevel EducationLevel
  difficulty     DifficultyLevel @default(MEDIUM)
  isPublished    Boolean         @default(false)
  isAiGenerated  Boolean         @default(false)
  playCount      Int             @default(0)
  thumbnailUrl   String?
  shareCode      String?         @unique

  // Tempat menyimpan soal (words, cards, questions)
  gameJson Json

  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     User          @relation("GameCreator", fields: [creatorId], references: [id])
  sessions    GameSession[]
  ltiContexts LtiContext[]

  @@index([educationLevel, templateType])
  @@map("games")
}

// ============================================================
// SESSION & RESULTS
// ============================================================

model GameSession {
  id          String    @id @default(uuid())
  gameId      String
  userId      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  isCompleted Boolean   @default(false)

  game   Game    @relation(fields: [gameId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  result Result?

  @@index([userId, gameId])
  @@map("game_sessions")
}

model Result {
  id               String          @id @default(uuid())
  sessionId        String          @unique
  scoreValue       Int             @default(0)
  maxScore         Int             @default(0)
  accuracy         Float           @default(0)
  timeSpent        Int             @default(0)
  difficultyPlayed DifficultyLevel @default(MEDIUM)

  answersDetail   Json  @default("[]")
  aiGradingResult Json?
  completedAt DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id])

  @@map("results")
}

// ============================================================
// LTI INTEGRATION
// ============================================================

model LtiContext {
  id                String   @id @default(uuid())
  gameId            String
  ltiContextId      String
  moodleCourseId    String
  moodleCourseName  String
  moodleInstanceUrl String
  createdAt         DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id])

  @@unique([ltiContextId, moodleInstanceUrl])
  @@map("lti_contexts")
}

// ============================================================
// SYSTEM LOGS
// ============================================================

model SystemLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String?
  userName  String?
  createdAt DateTime @default(now())

  @@map("system_logs")
}