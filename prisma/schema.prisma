generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────

enum Role {
  STUDENT
  CREATOR
  ADMIN
}

enum EducationLevel {
  SD
  SMP_SMA
  UNIVERSITY
}

enum TemplateType {
  QUIZ
  TRUE_OR_FALSE
  FLASHCARD
  MATCHING_PAIR
  WORD_SEARCH
  SHORT_ANSWER
  HANGMAN
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

// ─── USER ────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      UserProfile?
  gamesCreated Game[]        @relation("GameCreator")
  sessions     GameSession[]

  @@map("users")
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  bio         String?
  totalPoints Int      @default(0)
  badges      Json     @default("[]")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ─── GAME ─────────────────────────────────────────────────────────────

model Game {
  id             String          @id @default(uuid())
  title          String
  description    String?
  templateType   TemplateType
  educationLevel EducationLevel
  difficulty     DifficultyLevel @default(MEDIUM)
  isPublished    Boolean         @default(false)
  isAiGenerated  Boolean         @default(false)
  playCount      Int             @default(0)
  thumbnailUrl   String?
  shareCode      String?         @unique

  // Semua soal & jawaban disimpan di sini
  gameJson Json

  creatorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     User          @relation("GameCreator", fields: [creatorId], references: [id])
  sessions    GameSession[]
  ltiContexts LtiContext[]

  @@map("games")
}

// ─── GAME SESSION ─────────────────────────────────────────────────────

model GameSession {
  id          String    @id @default(uuid())
  gameId      String
  userId      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  isCompleted Boolean   @default(false)

  game   Game   @relation(fields: [gameId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  result Result?

  @@map("game_sessions")
}

// ─── RESULT ───────────────────────────────────────────────────────────

model Result {
  id               String          @id @default(uuid())
  sessionId        String          @unique
  scoreValue       Int             @default(0)
  maxScore         Int             @default(0)
  accuracy         Float           @default(0)
  timeSpent        Int             @default(0)
  difficultyPlayed DifficultyLevel @default(MEDIUM)

  // Detail jawaban per soal
  answersDetail   Json  @default("[]")
  
  // Hasil AI grading (untuk SHORT_ANSWER)
  aiGradingResult Json?

  completedAt DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id])

  @@map("results")
}

// ─── LTI / MOODLE ─────────────────────────────────────────────────────

model LtiContext {
  id                String   @id @default(uuid())
  gameId            String
  ltiContextId      String
  moodleCourseId    String
  moodleCourseName  String
  moodleInstanceUrl String
  createdAt         DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id])

  @@unique([ltiContextId, moodleInstanceUrl])
  @@map("lti_contexts")
}